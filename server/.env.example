# Server Environment Configuration
# This file should be copied to .env and updated with your values

PORT=5000
NODE_ENV=development

# Database (MongoDB) - Replace with your MongoDB Atlas URI
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatapp

# JWT Secrets - GENERATE NEW ONES IN PRODUCTION!
JWT_SECRET=generate_a_random_secret_key_for_production
JWT_REFRESH_SECRET=generate_another_random_secret_key_for_production
JWT_EXPIRE=7d

# CORS - Update with your client URL
CLIENT_URL=http://localhost:5173

# Email Configuration - Set up with your email service
# Options: Gmail, SendGrid, Mailtrap, AWS SES, etc.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_email_service_user
SMTP_PASS=your_email_service_password
SMTP_FROM=noreply@yourdomain.com
SMTP_SECURE=false

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpeg,jpg,png,gif,webp,pdf,doc,docx,mp3,wav,webm

# Session Configuration
SESSION_SECRET=generate_a_session_secret
